# Aion Memory — 本地开发环境变量（Docker Compose 或手动启动用）
# 警告：此文件含密码，已加入 .gitignore，禁止提交到 Git

# PostgreSQL（amber-db 容器）
POSTGRES_USER=postgres
POSTGRES_PASSWORD=amber
POSTGRES_DB=amber
PG_DSN=postgresql://postgres:amber@amber-db:5432/amber

# Amber API
MNEMOSYNE_DEV_INSECURE=1
MNEMOSYNE_API_KEY=
MNEMOSYNE_TENANT_ID=default

# 网络
DOCKER_NETWORK=amber-net
